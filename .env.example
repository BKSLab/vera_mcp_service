# --- Приложение ---
LOGGING_CONFIG_PATH=logging.ini

# --- Запуск MCP-сервера (app/main.py, streamable-http, MCP_SERVICE_PLAN.md, раздел 0.1) ---
MCP_SERVICE_HOST=0.0.0.0
MCP_SERVICE_PORT=8000

# --- Production endpoints: Docker Compose (активный шаблон) ---
# Все сервисы развёртываются на production-хосте 91.218.115.104 и обращаются
# друг к другу через опубликованные порты. localhost/127.0.0.1 здесь использовать нельзя.
RAG_SERVICE_URL=http://91.218.115.104:8002
PHOENIX_OTLP_ENDPOINT=http://91.218.115.104:6006/v1/traces

# --- Local endpoints: запуск `python -m app.main` на хосте (неактивно) ---
# Для локального режима закомментировать production endpoints выше и
# раскомментировать эти две строки.
# RAG_SERVICE_URL=http://127.0.0.1:8002
# PHOENIX_OTLP_ENDPOINT=http://127.0.0.1:6006/v1/traces

# --- RAG Service (POST /api/v1/search, vera_rag_service/README.md) ---
RAG_SERVICE_API_KEY=your_rag_service_api_key
RAG_SEARCH_TIMEOUT_SECONDS=10.0
RAG_SEARCH_TOP_K=5
