# --- Приложение ---
LOGGING_CONFIG_PATH=logging.ini

# --- Запуск MCP-сервера (app/main.py, streamable-http, MCP_SERVICE_PLAN.md, раздел 0.1) ---
MCP_SERVICE_HOST=0.0.0.0
MCP_SERVICE_PORT=8000

# --- RAG Service (POST /api/v1/search, vera_rag_service/README.md) ---
RAG_SERVICE_URL=http://localhost:8000
RAG_SERVICE_API_KEY=your_rag_service_api_key
RAG_SEARCH_TIMEOUT_SECONDS=10.0
RAG_SEARCH_TOP_K=5

# --- Observability (Arize Phoenix) ---
PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces
